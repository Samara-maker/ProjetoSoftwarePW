<h2>Categorias de Serviço</h2>
<a href="/categorias/nova" class="btn btn-primary">+ Nova Categoria</a>

<table class="tabela">
  <thead>
    <tr>
      <th>#</th>
      <th>Nome</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% if (categorias.length === 0) { %>
      <tr><td colspan="3">Nenhuma categoria cadastrada.</td></tr>
    <% } %>
    <% categorias.forEach(c => { %>
    <tr>
      <td><%= c.id %></td>
      <td><%= c.nome %></td>
      <td>
        <a href="/categorias/<%= c.id %>/editar" class="btn btn-sm btn-warning">Editar</a>
        <form action="/categorias/<%= c.id %>/excluir" method="POST" style="display:inline">
          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Excluir?')">Excluir</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
