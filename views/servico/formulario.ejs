<h2><%= titulo %></h2>

<form action="/servicos/<%= servico ? servico.id + '/editar' : 'novo' %>" method="POST" class="formulario">
  <div class="campo">
    <label for="descricao">Descrição *</label>
    <input type="text" id="descricao" name="descricao" value="<%= servico ? servico.descricao : '' %>" required />
  </div>

  <div class="campo">
    <label for="valor">Valor (R$) *</label>
    <input type="number" id="valor" name="valor" step="0.01" min="0" value="<%= servico ? servico.valor : '' %>" required />
  </div>

  <div class="campo">
    <label for="categoria_id">Categoria *</label>
    <select id="categoria_id" name="categoria_id" required>
      <option value="">-- Selecione --</option>
      <% categorias.forEach(c => { %>
        <option value="<%= c.id %>" <%= servico && servico.categoria && servico.categoria.id == c.id ? 'selected' : '' %>>
          <%= c.nome %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="acoes-formulario">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/servicos" class="btn btn-secondary">Cancelar</a>
  </div>
</form>
