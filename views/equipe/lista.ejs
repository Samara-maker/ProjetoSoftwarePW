<h2>Equipes</h2>
<a href="/equipes/nova" class="btn btn-primary">+ Nova Equipe</a>

<table class="tabela">
  <thead>
    <tr>
      <th>#</th>
      <th>Nome</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% if (equipes.length === 0) { %>
      <tr><td colspan="3">Nenhuma equipe cadastrada.</td></tr>
    <% } %>
    <% equipes.forEach(e => { %>
    <tr>
      <td><%= e.id %></td>
      <td><%= e.nome %></td>
      <td>
        <a href="/equipes/<%= e.id %>/editar" class="btn btn-sm btn-warning">Editar</a>
        <form action="/equipes/<%= e.id %>/excluir" method="POST" style="display:inline">
          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Excluir?')">Excluir</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
