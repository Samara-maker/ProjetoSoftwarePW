<h2><%= titulo %></h2>

<form action="/equipes/<%= equipe ? equipe.id + '/editar' : 'nova' %>" method="POST" class="formulario">
  <div class="campo">
    <label for="nome">Nome da Equipe *</label>
    <input type="text" id="nome" name="nome" value="<%= equipe ? equipe.nome : '' %>" required />
  </div>

  <div class="acoes-formulario">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/equipes" class="btn btn-secondary">Cancelar</a>
  </div>
</form>
