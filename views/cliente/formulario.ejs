<h2><%= titulo %></h2>

<form action="/clientes/<%= cliente ? cliente.id + '/editar' : 'novo' %>" method="POST" class="formulario">
  <div class="campo">
    <label for="nome">Nome *</label>
    <input type="text" id="nome" name="nome" value="<%= cliente ? cliente.nome : '' %>" required />
  </div>

  <div class="campo">
    <label for="email">Email *</label>
    <input type="email" id="email" name="email" value="<%= cliente ? cliente.email : '' %>" required />
  </div>

  <div class="campo">
    <label for="telefone">Telefone *</label>
    <input type="text" id="telefone" name="telefone" value="<%= cliente ? cliente.telefone : '' %>" required />
  </div>

  <div class="acoes-formulario">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/clientes" class="btn btn-secondary">Cancelar</a>
  </div>
</form>
